<?xml version="1.0" encoding="UTF-8"?>
<ConnectedApp xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Delivery Hub Companion</label>
    <contactEmail>support@cloudnimbusllc.com</contactEmail>
    <description>OAuth 2.0 for the Delivery Hub Companion Chrome Extension. Enables field reps to log hours, create work items, and dictate voice notes from any browser tab.</description>
    <oauthConfig>
        <callbackUrl>https://login.salesforce.com/services/oauth2/success</callbackUrl>
        <isAdminApproved>false</isAdminApproved>
        <isConsumerSecretOptional>true</isConsumerSecretOptional>
        <isIntrospectAllTokens>false</isIntrospectAllTokens>
        <scopes>Api</scopes>
        <scopes>RefreshToken</scopes>
    </oauthConfig>
</ConnectedApp>
