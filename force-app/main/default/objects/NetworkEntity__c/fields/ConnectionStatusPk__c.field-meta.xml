<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>ConnectionStatusPk__c</fullName>
    <description>Tracks the API connection lifecycle for this entity. Pending = awaiting key exchange, Connected = actively syncing, Disabled = API access revoked.</description>
    <inlineHelpText>Current state of the API connection with this entity.</inlineHelpText>
    <label>Connection Status</label>
    <required>false</required>
    <trackTrending>false</trackTrending>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Pending</fullName>
                <default>true</default>
                <label>Pending</label>
            </value>
            <value>
                <fullName>Connected</fullName>
                <default>false</default>
                <label>Connected</label>
            </value>
            <value>
                <fullName>Disabled</fullName>
                <default>false</default>
                <label>Disabled</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
