<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VerificationMethodPk__c</fullName>
    <description>How this item gets marked done. Manual = operator self-attests via the LWC button. SoqlQuery = PR 4+ will execute VerificationQueryTxt and pass when COUNT() returns at least 1. RestCall = PR 4+ will GET the URL and pass on HTTP 2xx. WebhookReceived = PR 4+ will pass once an inbound webhook matching VerificationQueryTxt arrives. In the MVP all four resolve to manual-attest.</description>
    <externalId>false</externalId>
    <fieldManageability>DeveloperControlled</fieldManageability>
    <label>Verification Method</label>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Manual</fullName>
                <default>true</default>
                <label>Manual</label>
            </value>
            <value>
                <fullName>SoqlQuery</fullName>
                <default>false</default>
                <label>SOQL Query</label>
            </value>
            <value>
                <fullName>RestCall</fullName>
                <default>false</default>
                <label>REST Call</label>
            </value>
            <value>
                <fullName>WebhookReceived</fullName>
                <default>false</default>
                <label>Webhook Received</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
