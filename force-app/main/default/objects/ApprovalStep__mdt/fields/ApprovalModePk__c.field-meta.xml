    <fieldManageability>DeveloperControlled</fieldManageability>
    <label>Approval Mode</label>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Sequential</fullName>
                <default>true</default>
                <label>Sequential</label>
            </value>
            <value>
                <fullName>Parallel</fullName>
                <default>false</default>
                <label>Parallel</label>
            </value>
            <value>
                <fullName>Any</fullName>
                <default>false</default>
                <label>Any</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
