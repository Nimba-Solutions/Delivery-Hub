<apex:page controller="DeliveryDocumentPdfController" showHeader="false" sidebar="false" standardStylesheets="false" renderAs="{!IF(renderAsPdf, 'pdf', '')}">
<head>
<style>
    body { font-family: Arial, Helvetica, sans-serif; font-size: 9pt; color: #222222; margin: 0; padding: 0; }
    table { border-collapse: collapse; }
</style>
</head>

<apex:outputPanel rendered="{!hasDocument}">

<!-- Blue top bar -->
<div style="background-color: #0176d3; height: 6px; width: 100%; margin-bottom: 0px;"></div>

<!-- HEADER -->
<table style="width: 100%; margin-bottom: 12px; padding: 12px 0; border-bottom: 2px solid #0176d3;" cellpadding="0" cellspacing="0">
    <tr>
        <td style="vertical-align: top; width: 60%; padding: 0;">
            <div style="font-size: 20pt; font-weight: bold; color: #0176d3; letter-spacing: 0.5px;">Cloud Nimbus LLC</div>
            <div style="font-size: 8pt; color: #888888; margin-top: 2px;">cloudnimbusllc.com</div>
        </td>
        <td style="vertical-align: top; width: 40%; text-align: right; padding: 0;">
            <div style="font-size: 14pt; font-weight: bold; color: #222222; text-transform: uppercase; letter-spacing: 1px;">{!templateDisplay}</div>
            <div style="font-size: 9pt; color: #888888; margin-top: 4px;">{!documentName}</div>
        </td>
    </tr>
</table>

<!-- BILL TO / DETAILS -->
<table style="width: 100%; margin-bottom: 14px;" cellpadding="0" cellspacing="0">
    <tr>
        <td style="vertical-align: top; width: 55%; padding: 8px 20px 8px 0;">
            <div style="font-size: 7pt; font-weight: bold; text-transform: uppercase; color: #888888; letter-spacing: 1px; margin-bottom: 4px;">
                <apex:outputText value="Bill To" rendered="{!isInvoice}" />
                <apex:outputText value="Prepared For" rendered="{!NOT(isInvoice)}" />
            </div>
            <div style="font-size: 12pt; font-weight: bold; color: #222222; margin-bottom: 3px;">{!entityName}</div>
            <apex:outputPanel rendered="{!entityAddress != null}"><div style="font-size: 9pt; color: #555555; line-height: 1.5;">{!entityAddress}</div></apex:outputPanel>
            <apex:outputPanel rendered="{!entityEmail != null}"><div style="font-size: 9pt; color: #555555; line-height: 1.5;">{!entityEmail}</div></apex:outputPanel>
            <apex:outputPanel rendered="{!entityPhone != null}"><div style="font-size: 9pt; color: #555555; line-height: 1.5;">{!entityPhone}</div></apex:outputPanel>
        </td>
        <td style="vertical-align: top; width: 45%; padding: 8px 0;">
            <table style="width: 100%; border: 1px solid #cccccc;" cellpadding="0" cellspacing="0">
                <apex:outputPanel rendered="{!formattedPeriod != null}">
                    <tr>
                        <td style="font-size: 7pt; font-weight: bold; text-transform: uppercase; color: #888888; padding: 5px 8px; border-bottom: 1px solid #eeeeee; width: 40%;">Period</td>
                        <td style="font-size: 9pt; color: #222222; padding: 5px 8px; border-bottom: 1px solid #eeeeee; text-align: right;">{!formattedPeriod}</td>
                    </tr>
                </apex:outputPanel>
                <apex:outputPanel rendered="{!hasTerms}">
                    <tr>
                        <td style="font-size: 7pt; font-weight: bold; text-transform: uppercase; color: #888888; padding: 5px 8px; border-bottom: 1px solid #eeeeee;">Terms</td>
                        <td style="font-size: 9pt; font-weight: bold; color: #222222; padding: 5px 8px; border-bottom: 1px solid #eeeeee; text-align: right;">{!terms}</td>
                    </tr>
                </apex:outputPanel>
                <apex:outputPanel rendered="{!hasDueDate}">
                    <tr>
                        <td style="font-size: 7pt; font-weight: bold; text-transform: uppercase; color: #888888; padding: 5px 8px; border-bottom: 1px solid #eeeeee;">Due Date</td>
                        <td style="font-size: 9pt; font-weight: bold; color: #222222; padding: 5px 8px; border-bottom: 1px solid #eeeeee; text-align: right;">{!formattedDueDate}</td>
                    </tr>
                </apex:outputPanel>
                <tr>
                    <td style="font-size: 7pt; font-weight: bold; text-transform: uppercase; color: #888888; padding: 5px 8px;">Rate</td>
                    <td style="font-size: 9pt; font-weight: bold; color: #222222; padding: 5px 8px; text-align: right;">{!formattedDefaultRate}</td>
                </tr>
            </table>
        </td>
    </tr>
</table>

<!-- SUMMARY BAR -->
<apex:outputPanel rendered="{!NOT(isAgreement)}">
    <table style="width: 100%; margin-bottom: 16px; border: 1px solid #cccccc;" cellpadding="0" cellspacing="0">
        <tr>
            <td style="width: 50%; text-align: center; padding: 12px 16px; background-color: #f0f0f0; border-right: 1px solid #cccccc;">
                <div style="font-size: 7pt; font-weight: bold; text-transform: uppercase; color: #888888; letter-spacing: 0.5px;">Total Hours</div>
                <div style="font-size: 14pt; font-weight: bold; color: #222222; margin-top: 2px;">{!formattedTotalHours}</div>
            </td>
            <td style="width: 50%; text-align: center; padding: 12px 16px; background-color: #f0f0f0;">
                <div style="font-size: 7pt; font-weight: bold; text-transform: uppercase; color: #888888; letter-spacing: 0.5px;">Total Amount</div>
                <div style="font-size: 14pt; font-weight: bold; color: #0176d3; margin-top: 2px;">{!formattedTotalCost}</div>
            </td>
        </tr>
    </table>
</apex:outputPanel>

<!-- WORK ITEMS -->
<apex:outputPanel rendered="{!hasWorkItems}">
    <div style="font-size: 9pt; font-weight: bold; text-transform: uppercase; letter-spacing: 0.5px; color: #222222; border-bottom: 1px solid #cccccc; padding-bottom: 4px; margin-top: 14px; margin-bottom: 6px;">Work Items</div>
    <table style="width: 100%; font-size: 8.5pt; border: 1px solid #cccccc;" cellpadding="0" cellspacing="0">
        <tr style="background-color: #333333;">
            <th style="color: #ffffff; font-size: 7pt; font-weight: bold; text-transform: uppercase; padding: 6px 8px; text-align: left; border-right: 1px solid #555555; width: 11%;">Name</th>
            <th style="color: #ffffff; font-size: 7pt; font-weight: bold; text-transform: uppercase; padding: 6px 8px; text-align: left; border-right: 1px solid #555555; width: 35%;">Description</th>
            <th style="color: #ffffff; font-size: 7pt; font-weight: bold; text-transform: uppercase; padding: 6px 8px; text-align: left; border-right: 1px solid #555555; width: 16%;">Stage</th>
            <th style="color: #ffffff; font-size: 7pt; font-weight: bold; text-transform: uppercase; padding: 6px 8px; text-align: right; border-right: 1px solid #555555; width: 10%;">Hours</th>
            <th style="color: #ffffff; font-size: 7pt; font-weight: bold; text-transform: uppercase; padding: 6px 8px; text-align: right; border-right: 1px solid #555555; width: 12%;">Rate</th>
            <th style="color: #ffffff; font-size: 7pt; font-weight: bold; text-transform: uppercase; padding: 6px 8px; text-align: right; width: 16%;">Subtotal</th>
        </tr>
        <apex:repeat value="{!workItemRows}" var="wi">
            <tr>
                <td style="padding: 5px 8px; border-bottom: 1px solid #eeeeee; border-right: 1px solid #eeeeee; font-weight: bold;">{!wi.name}</td>
                <td style="padding: 5px 8px; border-bottom: 1px solid #eeeeee; border-right: 1px solid #eeeeee;">{!wi.description}</td>
                <td style="padding: 5px 8px; border-bottom: 1px solid #eeeeee; border-right: 1px solid #eeeeee;">{!wi.stage}</td>
                <td style="padding: 5px 8px; border-bottom: 1px solid #eeeeee; border-right: 1px solid #eeeeee; text-align: right;">{!wi.hours}</td>
                <td style="padding: 5px 8px; border-bottom: 1px solid #eeeeee; border-right: 1px solid #eeeeee; text-align: right;">{!wi.formattedRate}</td>
                <td style="padding: 5px 8px; border-bottom: 1px solid #eeeeee; text-align: right; font-weight: bold;">{!wi.formattedSubtotal}</td>
            </tr>
        </apex:repeat>
    </table>
</apex:outputPanel>

<!-- WORK LOGS -->
<apex:outputPanel rendered="{!hasWorkLogs}">
    <div style="font-size: 9pt; font-weight: bold; text-transform: uppercase; letter-spacing: 0.5px; color: #222222; border-bottom: 1px solid #cccccc; padding-bottom: 4px; margin-top: 14px; margin-bottom: 6px;">Time Log Detail</div>
    <table style="width: 100%; font-size: 8.5pt; border: 1px solid #cccccc;" cellpadding="0" cellspacing="0">
        <tr style="background-color: #333333;">
            <th style="color: #ffffff; font-size: 7pt; font-weight: bold; text-transform: uppercase; padding: 6px 8px; text-align: left; border-right: 1px solid #555555; width: 14%;">Date</th>
            <th style="color: #ffffff; font-size: 7pt; font-weight: bold; text-transform: uppercase; padding: 6px 8px; text-align: left; border-right: 1px solid #555555; width: 12%;">Work Item</th>
            <th style="color: #ffffff; font-size: 7pt; font-weight: bold; text-transform: uppercase; padding: 6px 8px; text-align: right; border-right: 1px solid #555555; width: 10%;">Hours</th>
            <th style="color: #ffffff; font-size: 7pt; font-weight: bold; text-transform: uppercase; padding: 6px 8px; text-align: left; width: 64%;">Description</th>
        </tr>
        <apex:repeat value="{!workLogRows}" var="wl">
            <tr>
                <td style="padding: 5px 8px; border-bottom: 1px solid #eeeeee; border-right: 1px solid #eeeeee;">{!wl.workDate}</td>
                <td style="padding: 5px 8px; border-bottom: 1px solid #eeeeee; border-right: 1px solid #eeeeee; font-weight: bold;">{!wl.workItemName}</td>
                <td style="padding: 5px 8px; border-bottom: 1px solid #eeeeee; border-right: 1px solid #eeeeee; text-align: right;">{!wl.hours}</td>
                <td style="padding: 5px 8px; border-bottom: 1px solid #eeeeee;">{!wl.description}</td>
            </tr>
        </apex:repeat>
    </table>
</apex:outputPanel>

<!-- AI NARRATIVE -->
<apex:outputPanel rendered="{!hasAiNarrative}">
    <div style="font-size: 9pt; font-weight: bold; text-transform: uppercase; letter-spacing: 0.5px; color: #222222; border-bottom: 1px solid #cccccc; padding-bottom: 4px; margin-top: 14px; margin-bottom: 6px;">Summary</div>
    <div style="border-left: 3px solid #0176d3; background-color: #f5f5f5; padding: 10px 14px; font-size: 8.5pt; line-height: 1.6; color: #444444;">
        <apex:outputText value="{!aiNarrative}" escape="false" />
    </div>
</apex:outputPanel>

<!-- SIGNATURES (Agreements only) -->
<apex:outputPanel rendered="{!isAgreement}">
    <table style="width: 100%; margin-top: 40px;" cellpadding="0" cellspacing="0">
        <tr>
            <td style="width: 42%; padding-right: 16%;">
                <div style="border-top: 1px solid #222222; padding-top: 4px; font-size: 7.5pt; color: #888888;">Cloud Nimbus LLC - Authorized Signature</div>
                <div style="border-top: 1px solid #222222; padding-top: 4px; font-size: 7.5pt; color: #888888; margin-top: 30px;">Date</div>
            </td>
            <td style="width: 42%;">
                <div style="border-top: 1px solid #222222; padding-top: 4px; font-size: 7.5pt; color: #888888;">{!entityName} - Authorized Signature</div>
                <div style="border-top: 1px solid #222222; padding-top: 4px; font-size: 7.5pt; color: #888888; margin-top: 30px;">Date</div>
            </td>
        </tr>
    </table>
</apex:outputPanel>

<!-- FOOTER -->
<table style="width: 100%; border-top: 2px solid #0176d3; padding-top: 10px; margin-top: 20px;" cellpadding="0" cellspacing="0">
    <tr>
        <td style="width: 50%; font-size: 8.5pt; color: #888888; vertical-align: bottom;">
            <apex:outputPanel rendered="{!hasTerms}">Terms: {!terms}</apex:outputPanel>
        </td>
        <td style="width: 50%; text-align: right; vertical-align: bottom;">
            <apex:outputPanel rendered="{!NOT(isAgreement)}">
                <apex:outputPanel rendered="{!hasPriorBalance}">
                    <div style="padding-bottom: 4px;">
                        <span style="font-size: 8pt; color: #888888;">Prior Balance:</span>
                        <span style="font-size: 10pt; font-weight: bold; padding-left: 6px;">{!formattedPriorBalance}</span>
                    </div>
                    <div style="padding-bottom: 4px;">
                        <span style="font-size: 8pt; color: #888888;">Current Charges:</span>
                        <span style="font-size: 10pt; font-weight: bold; padding-left: 6px;">{!formattedTotalCost}</span>
                    </div>
                </apex:outputPanel>
                <div style="font-size: 8pt; color: #888888;">Total Due</div>
                <div style="font-size: 18pt; font-weight: bold; color: #0176d3;">{!formattedAmountDue}</div>
            </apex:outputPanel>
        </td>
    </tr>
</table>

<div style="font-size: 7pt; color: #bbbbbb; text-align: center; padding-top: 16px;">Cloud Nimbus LLC - cloudnimbusllc.com - Powered by Delivery Hub</div>

</apex:outputPanel>

<!-- No document -->
<apex:outputPanel rendered="{!NOT(hasDocument)}">
    <div style="text-align: center; padding: 60px; color: #888888;">
        <p style="font-size: 14pt;">Document not found.</p>
    </div>
</apex:outputPanel>

</apex:page>
