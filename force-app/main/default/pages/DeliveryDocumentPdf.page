<apex:page controller="DeliveryDocumentPdfController" showHeader="false" sidebar="false" standardStylesheets="false" renderAs="{!IF(renderAsPdf, 'pdf', '')}">
<head>
<style>
    body { font-family: Arial, Helvetica, sans-serif; font-size: 9pt; color: #222222; margin: 0; padding: 20px 30px; }
    table { border-collapse: collapse; page-break-inside: auto; }
    tr { page-break-inside: avoid; page-break-after: auto; }
    thead { display: table-header-group; }
    @page { margin: 0.5in 0.4in; }
</style>
</head>

<apex:outputPanel rendered="{!hasDocument}">

<!-- ========== COMPANY HEADER ========== -->
<table style="width: 100%; border-bottom: 3px solid #333333; padding-bottom: 8px; margin-bottom: 12px;" cellpadding="0" cellspacing="0">
    <tr>
        <td style="vertical-align: top; width: 55%;">
            <div style="font-size: 16pt; font-weight: bold; color: #333333;">{!vendorName}</div>
            <div style="font-size: 8pt; color: #555555; line-height: 1.5;">
                <apex:outputText value="{!vendorAddress}" escape="false" />
            </div>
        </td>
        <td style="vertical-align: top; width: 20%; text-align: left;">
            <apex:outputPanel rendered="{!vendorPhone != null}">
                <div style="font-size: 8pt; color: #555555; padding-top: 4px;">{!vendorPhone}</div>
            </apex:outputPanel>
            <apex:outputPanel rendered="{!vendorEmail != null}">
                <div style="font-size: 8pt; color: #555555;">{!vendorEmail}</div>
            </apex:outputPanel>
        </td>
        <td style="vertical-align: top; width: 25%; text-align: right;">
            <div style="font-size: 18pt; font-weight: bold; font-style: italic; color: #333333;">{!templateDisplay}</div>
        </td>
    </tr>
</table>

<!-- ========== SOLD TO + INVOICE DETAILS ========== -->
<table style="width: 100%; margin-bottom: 12px;" cellpadding="0" cellspacing="0">
    <tr>
        <td style="vertical-align: top; width: 50%; padding-right: 16px;">
            <!-- SOLD TO -->
            <div style="font-size: 8pt; font-weight: bold; color: #333333; margin-bottom: 4px;">
                <apex:outputText value="SOLD TO:" rendered="{!isInvoice}" />
                <apex:outputText value="PREPARED FOR:" rendered="{!NOT(isInvoice)}" />
            </div>
            <div style="font-size: 9pt; color: #333333; line-height: 1.6;">
                {!entityName}<br/>
                <apex:outputPanel rendered="{!entityAddress != null}">{!entityAddress}<br/></apex:outputPanel>
                <apex:outputPanel rendered="{!entityEmail != null}">{!entityEmail}<br/></apex:outputPanel>
                <apex:outputPanel rendered="{!entityPhone != null}">{!entityPhone}</apex:outputPanel>
            </div>
        </td>
        <td style="vertical-align: top; width: 50%;">
            <!-- INVOICE DETAILS GRID -->
            <table style="width: 100%; border: 1px solid #999999;" cellpadding="0" cellspacing="0">
                <tr>
                    <td style="font-size: 7.5pt; font-weight: bold; color: #333333; padding: 3px 6px; border-bottom: 1px solid #cccccc; border-right: 1px solid #cccccc; text-align: right; width: 55%;">INVOICE NUMBER</td>
                    <td style="font-size: 8.5pt; color: #333333; padding: 3px 6px; border-bottom: 1px solid #cccccc;">{!documentName}</td>
                </tr>
                <tr>
                    <td style="font-size: 7.5pt; font-weight: bold; color: #333333; padding: 3px 6px; border-bottom: 1px solid #cccccc; border-right: 1px solid #cccccc; text-align: right;">INVOICE DATE</td>
                    <td style="font-size: 8.5pt; color: #333333; padding: 3px 6px; border-bottom: 1px solid #cccccc;">{!generatedAt}</td>
                </tr>
                <tr>
                    <td style="font-size: 7.5pt; font-weight: bold; color: #333333; padding: 3px 6px; border-bottom: 1px solid #cccccc; border-right: 1px solid #cccccc; text-align: right;">PERIOD</td>
                    <td style="font-size: 8.5pt; color: #333333; padding: 3px 6px; border-bottom: 1px solid #cccccc;">{!formattedPeriod}</td>
                </tr>
                <tr>
                    <td style="font-size: 7.5pt; font-weight: bold; color: #333333; padding: 3px 6px; border-bottom: 1px solid #cccccc; border-right: 1px solid #cccccc; text-align: right;">TERMS</td>
                    <td style="font-size: 8.5pt; font-weight: bold; color: #333333; padding: 3px 6px; border-bottom: 1px solid #cccccc;">{!IF(ISBLANK(terms), 'Net 30', terms)}</td>
                </tr>
                <tr>
                    <td style="font-size: 7.5pt; font-weight: bold; color: #333333; padding: 3px 6px; border-bottom: 1px solid #cccccc; border-right: 1px solid #cccccc; text-align: right;">RATE</td>
                    <td style="font-size: 8.5pt; font-weight: bold; color: #333333; padding: 3px 6px; border-bottom: 1px solid #cccccc;">{!formattedDefaultRate}</td>
                </tr>
                <apex:outputPanel layout="none" rendered="{!hasPriorBalance}">
                    <tr>
                        <td style="font-size: 7.5pt; font-weight: bold; color: #333333; padding: 3px 6px; border-bottom: 1px solid #cccccc; border-right: 1px solid #cccccc; text-align: right;">CURRENT ACCOUNT BALANCE</td>
                        <td style="font-size: 9pt; font-weight: bold; color: #333333; padding: 3px 6px; border-bottom: 1px solid #cccccc;">{!formattedPriorBalance}</td>
                    </tr>
                </apex:outputPanel>
                <apex:outputPanel layout="none" rendered="{!NOT(hasPriorBalance)}">
                    <tr>
                        <td style="font-size: 7.5pt; font-weight: bold; color: #333333; padding: 3px 6px; border-bottom: 1px solid #cccccc; border-right: 1px solid #cccccc; text-align: right;">CURRENT ACCOUNT BALANCE</td>
                        <td style="font-size: 9pt; font-weight: bold; color: #333333; padding: 3px 6px; border-bottom: 1px solid #cccccc;">$0.00</td>
                    </tr>
                </apex:outputPanel>
            </table>
        </td>
    </tr>
</table>

<!-- ========== AGREEMENT CLAUSES ========== -->
<apex:outputPanel rendered="{!hasAgreementClauses}">
    <div style="font-size: 9pt; color: #333333; margin-bottom: 8px; line-height: 1.6;">
        This Professional Services Agreement ("Agreement") is entered into by and between
        <strong>{!vendorName}</strong> and <strong>{!entityName}</strong>, effective as of the
        date of last signature below.
    </div>
    <apex:repeat value="{!agreementClauseRows}" var="clause">
        <div style="margin-bottom: 10px;">
            <div style="font-size: 9pt; font-weight: bold; color: #333333; margin-bottom: 3px;">
                {!clause.seq}. {!clause.title}
            </div>
            <div style="font-size: 8.5pt; color: #444444; line-height: 1.6; padding-left: 12px;">
                {!clause.body}
            </div>
        </div>
    </apex:repeat>
    <div style="border-top: 1px solid #cccccc; margin-top: 6px; margin-bottom: 10px;"></div>
</apex:outputPanel>

<!-- ========== WORK ITEMS ========== -->
<apex:outputPanel layout="none" rendered="{!hasWorkItems}">
    <table style="width: 100%; font-size: 8pt; border: 1px solid #999999; margin-bottom: 4px;" cellpadding="0" cellspacing="0">
        <tr style="background-color: #e8e8e8;">
            <th style="font-size: 7pt; font-weight: bold; padding: 4px 6px; text-align: left; border-bottom: 1px solid #999999; border-right: 1px solid #cccccc; width: 10%;">NAME</th>
            <th style="font-size: 7pt; font-weight: bold; padding: 4px 6px; text-align: left; border-bottom: 1px solid #999999; border-right: 1px solid #cccccc; width: 32%;">DESCRIPTION</th>
            <th style="font-size: 7pt; font-weight: bold; padding: 4px 6px; text-align: left; border-bottom: 1px solid #999999; border-right: 1px solid #cccccc; width: 12%;">STAGE</th>
            <th style="font-size: 7pt; font-weight: bold; padding: 4px 6px; text-align: right; border-bottom: 1px solid #999999; border-right: 1px solid #cccccc; width: 9%;">PERIOD HRS</th>
            <th style="font-size: 7pt; font-weight: bold; padding: 4px 6px; text-align: right; border-bottom: 1px solid #999999; border-right: 1px solid #cccccc; width: 9%;">TOTAL HRS</th>
            <th style="font-size: 7pt; font-weight: bold; padding: 4px 6px; text-align: right; border-bottom: 1px solid #999999; border-right: 1px solid #cccccc; width: 12%;">RATE</th>
            <th style="font-size: 7pt; font-weight: bold; padding: 4px 6px; text-align: right; border-bottom: 1px solid #999999; width: 16%;">SUBTOTAL</th>
        </tr>
        <apex:repeat value="{!workItemRows}" var="wi">
            <tr>
                <td style="padding: 3px 6px; border-bottom: 1px solid #dddddd; border-right: 1px solid #eeeeee; font-weight: bold;">
                    <apex:outputPanel layout="none" rendered="{!NOT(renderAsPdf)}"><a href="/{!wi.id}" style="color: #0176d3; text-decoration: none;">{!wi.name}</a></apex:outputPanel>
                    <apex:outputPanel layout="none" rendered="{!renderAsPdf}">{!wi.name}</apex:outputPanel>
                </td>
                <td style="padding: 3px 6px; border-bottom: 1px solid #dddddd; border-right: 1px solid #eeeeee;">{!wi.description}</td>
                <td style="padding: 3px 6px; border-bottom: 1px solid #dddddd; border-right: 1px solid #eeeeee; font-size: 7.5pt;">{!wi.stage}</td>
                <td style="padding: 3px 6px; border-bottom: 1px solid #dddddd; border-right: 1px solid #eeeeee; text-align: right;">{!wi.hours}</td>
                <td style="padding: 3px 6px; border-bottom: 1px solid #dddddd; border-right: 1px solid #eeeeee; text-align: right; color: #888888;">{!wi.totalHours}</td>
                <td style="padding: 3px 6px; border-bottom: 1px solid #dddddd; border-right: 1px solid #eeeeee; text-align: right;">{!wi.formattedRate}</td>
                <td style="padding: 3px 6px; border-bottom: 1px solid #dddddd; text-align: right; font-weight: bold;">{!wi.formattedSubtotal}</td>
            </tr>
        </apex:repeat>
        <!-- TOTALS ROW -->
        <tr style="background-color: #f0f0f0; font-weight: bold;">
            <td style="padding: 4px 6px; border-top: 2px solid #999999; border-right: 1px solid #cccccc;" colspan="3">TOTAL ({!workItemCount} items)</td>
            <td style="padding: 4px 6px; border-top: 2px solid #999999; border-right: 1px solid #cccccc; text-align: right;">{!totalHours}</td>
            <td style="padding: 4px 6px; border-top: 2px solid #999999; border-right: 1px solid #cccccc; text-align: right; color: #888888;">{!grandTotalHours}</td>
            <td style="padding: 4px 6px; border-top: 2px solid #999999; border-right: 1px solid #cccccc; text-align: right;"></td>
            <td style="padding: 4px 6px; border-top: 2px solid #999999; text-align: right; font-size: 9pt;">{!formattedTotalCost}</td>
        </tr>
    </table>
</apex:outputPanel>

<!-- ========== TIME LOG DETAIL ========== -->
<apex:outputPanel rendered="{!hasWorkLogs}">
    <div style="font-size: 8pt; font-weight: bold; color: #333333; margin-top: 10px; margin-bottom: 4px;">TIME LOG DETAIL</div>
    <table style="width: 100%; font-size: 8pt; border: 1px solid #999999; margin-bottom: 4px;" cellpadding="0" cellspacing="0">
        <tr style="background-color: #e8e8e8;">
            <th style="font-size: 7pt; font-weight: bold; padding: 4px 6px; text-align: left; border-bottom: 1px solid #999999; border-right: 1px solid #cccccc; width: 12%;">DATE</th>
            <th style="font-size: 7pt; font-weight: bold; padding: 4px 6px; text-align: left; border-bottom: 1px solid #999999; border-right: 1px solid #cccccc; width: 10%;">WORK ITEM</th>
            <th style="font-size: 7pt; font-weight: bold; padding: 4px 6px; text-align: right; border-bottom: 1px solid #999999; border-right: 1px solid #cccccc; width: 8%;">HOURS</th>
            <th style="font-size: 7pt; font-weight: bold; padding: 4px 6px; text-align: right; border-bottom: 1px solid #999999; border-right: 1px solid #cccccc; width: 12%;">RATE</th>
            <th style="font-size: 7pt; font-weight: bold; padding: 4px 6px; text-align: right; border-bottom: 1px solid #999999; border-right: 1px solid #cccccc; width: 14%;">AMOUNT</th>
            <th style="font-size: 7pt; font-weight: bold; padding: 4px 6px; text-align: left; border-bottom: 1px solid #999999; width: 44%;">DESCRIPTION</th>
        </tr>
        <apex:repeat value="{!workLogRows}" var="wl">
            <tr>
                <td style="padding: 3px 6px; border-bottom: 1px solid #dddddd; border-right: 1px solid #eeeeee;">{!wl.workDate}</td>
                <td style="padding: 3px 6px; border-bottom: 1px solid #dddddd; border-right: 1px solid #eeeeee; font-weight: bold;">
                    <apex:outputPanel layout="none" rendered="{!NOT(renderAsPdf)}"><a href="/{!wl.workItemId}" style="color: #0176d3; text-decoration: none;">{!wl.workItemName}</a></apex:outputPanel>
                    <apex:outputPanel layout="none" rendered="{!renderAsPdf}">{!wl.workItemName}</apex:outputPanel>
                </td>
                <td style="padding: 3px 6px; border-bottom: 1px solid #dddddd; border-right: 1px solid #eeeeee; text-align: right;">{!wl.hours}</td>
                <td style="padding: 3px 6px; border-bottom: 1px solid #dddddd; border-right: 1px solid #eeeeee; text-align: right;">{!wl.formattedRate}</td>
                <td style="padding: 3px 6px; border-bottom: 1px solid #dddddd; border-right: 1px solid #eeeeee; text-align: right; font-weight: bold;">{!wl.formattedAmount}</td>
                <td style="padding: 3px 6px; border-bottom: 1px solid #dddddd;">{!wl.description}</td>
            </tr>
        </apex:repeat>
    </table>
</apex:outputPanel>

<!-- ========== AI NARRATIVE ========== -->
<apex:outputPanel rendered="{!hasAiNarrative}">
    <div style="font-size: 8pt; font-weight: bold; color: #333333; margin-top: 10px; margin-bottom: 4px;">SUMMARY</div>
    <div style="border-left: 3px solid #0176d3; background-color: #f5f5f5; padding: 8px 12px; font-size: 8pt; line-height: 1.6; color: #444444;">
        <apex:outputText value="{!aiNarrative}" escape="false" />
    </div>
</apex:outputPanel>

<!-- ========== SIGNATURES (Agreements) ========== -->
<apex:outputPanel rendered="{!isAgreement}">
    <table style="width: 100%; margin-top: 40px;" cellpadding="0" cellspacing="0">
        <tr>
            <td style="width: 42%; padding-right: 16%;">
                <div style="border-top: 1px solid #222222; padding-top: 4px; font-size: 7.5pt; color: #888888;">{!vendorName} - Authorized Signature</div>
                <div style="border-top: 1px solid #222222; padding-top: 4px; font-size: 7.5pt; color: #888888; margin-top: 30px;">Date</div>
            </td>
            <td style="width: 42%;">
                <div style="border-top: 1px solid #222222; padding-top: 4px; font-size: 7.5pt; color: #888888;">{!entityName} - Authorized Signature</div>
                <div style="border-top: 1px solid #222222; padding-top: 4px; font-size: 7.5pt; color: #888888; margin-top: 30px;">Date</div>
            </td>
        </tr>
    </table>
</apex:outputPanel>

<!-- ========== UNPAID INVOICES SUMMARY ========== -->
<apex:outputPanel rendered="{!hasUnpaidInvoices}">
    <div style="font-size: 8pt; font-weight: bold; color: #333333; margin-top: 10px; margin-bottom: 4px;">ACCOUNT RECEIVABLE SUMMARY</div>
    <table style="width: 100%; font-size: 8pt; border: 1px solid #999999; margin-bottom: 4px;" cellpadding="0" cellspacing="0">
        <tr style="background-color: #e8e8e8;">
            <th style="font-size: 7pt; font-weight: bold; padding: 4px 6px; text-align: left; border-bottom: 1px solid #999999; border-right: 1px solid #cccccc; width: 15%;">INVOICE</th>
            <th style="font-size: 7pt; font-weight: bold; padding: 4px 6px; text-align: left; border-bottom: 1px solid #999999; border-right: 1px solid #cccccc; width: 30%;">PERIOD</th>
            <th style="font-size: 7pt; font-weight: bold; padding: 4px 6px; text-align: right; border-bottom: 1px solid #999999; border-right: 1px solid #cccccc; width: 15%;">INVOICED</th>
            <th style="font-size: 7pt; font-weight: bold; padding: 4px 6px; text-align: right; border-bottom: 1px solid #999999; border-right: 1px solid #cccccc; width: 15%;">PAID</th>
            <th style="font-size: 7pt; font-weight: bold; padding: 4px 6px; text-align: right; border-bottom: 1px solid #999999; border-right: 1px solid #cccccc; width: 15%;">OUTSTANDING</th>
            <th style="font-size: 7pt; font-weight: bold; padding: 4px 6px; text-align: center; border-bottom: 1px solid #999999; width: 10%;">STATUS</th>
        </tr>
        <apex:repeat value="{!unpaidInvoiceRows}" var="inv">
            <tr>
                <td style="padding: 3px 6px; border-bottom: 1px solid #dddddd; border-right: 1px solid #eeeeee; font-weight: bold;">{!inv.name}</td>
                <td style="padding: 3px 6px; border-bottom: 1px solid #dddddd; border-right: 1px solid #eeeeee;">{!inv.period}</td>
                <td style="padding: 3px 6px; border-bottom: 1px solid #dddddd; border-right: 1px solid #eeeeee; text-align: right;">{!inv.formattedTotal}</td>
                <td style="padding: 3px 6px; border-bottom: 1px solid #dddddd; border-right: 1px solid #eeeeee; text-align: right;">{!inv.formattedPaid}</td>
                <td style="padding: 3px 6px; border-bottom: 1px solid #dddddd; border-right: 1px solid #eeeeee; text-align: right; font-weight: bold;">{!inv.formattedOutstanding}</td>
                <td style="padding: 3px 6px; border-bottom: 1px solid #dddddd; text-align: center; font-size: 7pt;">{!inv.status}</td>
            </tr>
        </apex:repeat>
    </table>
</apex:outputPanel>

<!-- ========== TOTALS BOX ========== -->
<apex:outputPanel rendered="{!NOT(isAgreement)}">
    <table style="width: 100%; margin-top: 8px;" cellpadding="0" cellspacing="0">
        <tr>
            <td style="width: 60%;"></td>
            <td style="width: 40%;">
                <table style="width: 100%; border: 1px solid #999999;" cellpadding="0" cellspacing="0">
                    <tr>
                        <td style="padding: 4px 8px; border-bottom: 1px solid #cccccc; font-size: 8pt; font-weight: bold; text-align: right; border-right: 1px solid #cccccc;">SUBTOTAL</td>
                        <td style="padding: 4px 8px; border-bottom: 1px solid #cccccc; font-size: 9pt; text-align: right; width: 35%;">{!formattedTotalCost}</td>
                    </tr>
                    <tr>
                        <td style="padding: 4px 8px; border-bottom: 1px solid #cccccc; font-size: 8pt; font-weight: bold; text-align: right; border-right: 1px solid #cccccc;">TAX</td>
                        <td style="padding: 4px 8px; border-bottom: 1px solid #cccccc; font-size: 9pt; text-align: right;">$0.00</td>
                    </tr>
                    <apex:outputPanel layout="none" rendered="{!hasPriorBalance}">
                        <tr>
                            <td style="padding: 4px 8px; border-bottom: 1px solid #cccccc; font-size: 8pt; font-weight: bold; text-align: right; border-right: 1px solid #cccccc;">PRIOR BALANCE</td>
                            <td style="padding: 4px 8px; border-bottom: 1px solid #cccccc; font-size: 9pt; text-align: right;">{!formattedPriorBalance}</td>
                        </tr>
                    </apex:outputPanel>
                    <tr style="background-color: #e8e8e8;">
                        <td style="padding: 5px 8px; font-size: 8pt; font-weight: bold; text-align: right; border-right: 1px solid #cccccc;">PAY THIS AMOUNT</td>
                        <td style="padding: 5px 8px; font-size: 11pt; font-weight: bold; text-align: right;">{!formattedAmountDue}</td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</apex:outputPanel>

<!-- ========== FOOTER ========== -->
<table style="width: 100%; border-top: 2px solid #333333; padding-top: 8px; margin-top: 16px;" cellpadding="0" cellspacing="0">
    <tr>
        <td style="width: 35%; vertical-align: top; padding-right: 12px;">
            <div style="font-size: 7.5pt; font-weight: bold; color: #333333; margin-bottom: 3px;">DIRECT ALL INQUIRIES TO:</div>
            <div style="font-size: 8pt; color: #555555; line-height: 1.5;">
                <apex:outputPanel rendered="{!vendorPhone != null}">{!vendorPhone}<br/></apex:outputPanel>
                <apex:outputPanel rendered="{!vendorEmail != null}">{!vendorEmail}</apex:outputPanel>
            </div>
        </td>
        <td style="width: 35%; vertical-align: top;">
            <div style="font-size: 7.5pt; font-weight: bold; color: #333333; margin-bottom: 3px;">MAKE ALL CHECKS PAYABLE TO:</div>
            <div style="font-size: 8pt; color: #555555; line-height: 1.5;">
                {!vendorName}<br/>
                Attn: Accounts Receivable<br/>
                <apex:outputText value="{!vendorAddress}" escape="false" />
            </div>
        </td>
        <td style="width: 30%; vertical-align: top; text-align: right;">
            <apex:outputPanel rendered="{!NOT(isAgreement)}">
                <div style="font-size: 12pt; font-weight: bold; color: #333333;">{!formattedAmountDue}</div>
                <div style="font-size: 7.5pt; font-weight: bold; color: #555555;">PAY THIS<br/>AMOUNT</div>
            </apex:outputPanel>
        </td>
    </tr>
</table>

<div style="font-size: 9pt; font-weight: bold; font-style: italic; text-align: center; padding-top: 12px; color: #333333;">THANK YOU FOR YOUR BUSINESS!</div>
<div style="font-size: 7pt; color: #888888; text-align: left; padding-top: 16px;">*3% a month charge to balance will accrue to overdue balances</div>
<div style="font-size: 7pt; color: #0176d3; text-align: center; padding-top: 8px;"><a href="https://cloudnimbusllc.com" style="color: #0176d3; text-decoration: none;">cloudnimbusllc.com</a> &middot; Powered by Delivery Hub</div>

</apex:outputPanel>

<apex:outputPanel rendered="{!NOT(hasDocument)}">
    <div style="text-align: center; padding: 60px; color: #888888;">
        <p style="font-size: 14pt;">Document not found.</p>
    </div>
</apex:outputPanel>

</apex:page>
