<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <description>Headless agent that subscribes to DeliveryWorkItemChange__e and triggers getRecordNotifyChange on the standard SF detail page so it auto-refreshes when other clients edit this record.</description>
    <isExposed>true</isExposed>
    <masterLabel>Delivery Hub Live Record Refresh</masterLabel>
    <targets>
        <target>lightning__RecordPage</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__RecordPage">
            <objects>
                <object>WorkItem__c</object>
            </objects>
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
