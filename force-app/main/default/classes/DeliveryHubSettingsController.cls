 * @description Controller class for managing Delivery Hub application settings
 * Handles General and AI configuration via Custom Settings.
 * @author Cloud Nimbus LLC
 */
@SuppressWarnings('PMD.CyclomaticComplexity, PMD.StdCyclomaticComplexity')
public with sharing class DeliveryHubSettingsController {

    /**
     * @description Data Transfer Object for settings data to/from LWC
     */
    public class SettingsDTO {
        /** @description Enable notifications setting */
        @AuraEnabled public Boolean enableNotifications { get; set; }
        
        /** @description Automatically create a Request record when a Work Item is created */
        @AuraEnabled public Boolean autoCreateRequest { get; set; } 
        
        /** @description Automatically send the Request to the Vendor via API */
        @AuraEnabled public Boolean autoSendRequest { get; set; }   
        
        /** @description AI suggestions enabled setting */
        @AuraEnabled public Boolean aiSuggestionsEnabled { get; set; }
        
        /** @description Auto generate descriptions setting */
        @AuraEnabled public Boolean autoGenerateDescriptions { get; set; }
        
        /** @description AI estimation enabled setting */
        @AuraEnabled public Boolean aiEstimationEnabled { get; set; }
        
        /** @description OpenAI API key */
        @AuraEnabled public String openaiApiKey { get; set; }
        
        /** @description OpenAI model name */
        @AuraEnabled public String openaiModel { get; set; }
        
        /** @description OpenAI API tested status */
        @AuraEnabled public Boolean openAiApiTested { get; set; }

        /** @description Slack Incoming Webhook URL */
        @AuraEnabled public String slackWebhookUrl { get; set; }

        /** @description Email notifications on stage changes */
        @AuraEnabled public Boolean emailNotificationsEnabled { get; set; }

        /** @description Show inline board metrics bar on the Kanban board */
        @AuraEnabled public Boolean showBoardMetrics { get; set; }

        // ── Activation-date strings (read-only in LWC) ────────────────────
        /** @description Formatted date when notifications were activated */
        @AuraEnabled public String notificationsActivatedAt { get; set; }
        /** @description Formatted date when auto-sync was activated */
        @AuraEnabled public String autoSyncActivatedAt { get; set; }
        /** @description Formatted date when email notifications were activated */
        @AuraEnabled public String emailNotificationsActivatedAt { get; set; }
        /** @description Formatted date when board metrics were activated */
        @AuraEnabled public String boardMetricsActivatedAt { get; set; }
        /** @description Formatted date when activity logging was activated */
        @AuraEnabled public String activityLoggingActivatedAt { get; set; }

        // ── Configurable number settings ──────────────────────────────────
        /** @description Hour (0-23) at which the reconciliation job runs */
        @AuraEnabled public Integer reconciliationHour { get; set; }
        /** @description Maximum retry attempts for failed syncs */
        @AuraEnabled public Integer syncRetryLimit { get; set; }
        /** @description Days to retain activity log records before cleanup */
        @AuraEnabled public Integer activityLogRetentionDays { get; set; }
        /** @description Hours between repeated escalation notifications */
        @AuraEnabled public Integer escalationCooldownHours { get; set; }
    }

    /**
     * @description Fetches settings. Not cacheable to ensure fresh reload.
     * @return SettingsDTO The aggregated settings object.
     */
    @SuppressWarnings('PMD.CyclomaticComplexity')
    @AuraEnabled
    public static SettingsDTO getSettings() {
        DeliveryHubSettings__c settings = DeliveryHubSettings__c.getOrgDefaults();
        SettingsDTO dto = new SettingsDTO();

        if (settings != null && settings.Id != null) {
            dto.enableNotifications = settings.EnableNotificationsDateTime__c != null;

            // Map new fields
            dto.autoCreateRequest = settings.EnableAutoCreateWorkRequestDateTime__c != null;
            dto.autoSendRequest = settings.EnableAutoSyncNetworkEntityDateTime__c != null;

            // Map AI fields
            dto.aiSuggestionsEnabled = settings.EnableAISuggestionsDateTime__c != null;
            dto.autoGenerateDescriptions = settings.EnableAutoGenerateDescriptionsDateTime__c != null;
            dto.aiEstimationEnabled = settings.EnableAIEstimationDateTime__c != null;
            dto.openaiApiKey = String.isNotBlank(settings.OpenAIApiKeyTxt__c)
                ? '****' + settings.OpenAIApiKeyTxt__c.right(4)
                : null;
            dto.openaiModel = settings.OpenAIModelTxt__c;
            dto.openAiApiTested = settings.OpenAiApiTestedBool__c;
            dto.slackWebhookUrl = settings.SlackWebhookUrl__c;
            dto.emailNotificationsEnabled = settings.EnableEmailNotificationsDateTime__c != null;
            dto.showBoardMetrics = settings.EnableBoardMetricsDateTime__c != null;

            // Activation-date strings
            dto.notificationsActivatedAt = formatActivationDate(settings.EnableNotificationsDateTime__c);
            dto.autoSyncActivatedAt = formatActivationDate(settings.EnableAutoSyncNetworkEntityDateTime__c);
            dto.emailNotificationsActivatedAt = formatActivationDate(settings.EnableEmailNotificationsDateTime__c);
            dto.boardMetricsActivatedAt = formatActivationDate(settings.EnableBoardMetricsDateTime__c);
            dto.activityLoggingActivatedAt = formatActivationDate(settings.EnableActivityLoggingDateTime__c);

            // Configurable number settings (with defaults)
            dto.reconciliationHour = settings.ReconciliationHourNumber__c != null
                ? Integer.valueOf(settings.ReconciliationHourNumber__c) : 6;
            dto.syncRetryLimit = settings.SyncRetryLimitNumber__c != null
                ? Integer.valueOf(settings.SyncRetryLimitNumber__c) : 3;
            dto.activityLogRetentionDays = settings.ActivityLogRetentionDaysNumber__c != null
                ? Integer.valueOf(settings.ActivityLogRetentionDaysNumber__c) : 90;
            dto.escalationCooldownHours = settings.EscalationCooldownHoursNumber__c != null
                ? Integer.valueOf(settings.EscalationCooldownHoursNumber__c) : 24;
        } else {
            // Fresh Install Defaults — match what DeliveryHubInstallHandler sets
            dto.enableNotifications = true;
            dto.autoCreateRequest = true;
            dto.autoSendRequest = true;
            dto.emailNotificationsEnabled = true;
            dto.showBoardMetrics = true;
            dto.aiSuggestionsEnabled = true;
            dto.autoGenerateDescriptions = true;
            dto.aiEstimationEnabled = true;
            dto.reconciliationHour = 6;
            dto.syncRetryLimit = 3;
            dto.activityLogRetentionDays = 90;
            dto.escalationCooldownHours = 24;
        }
        return dto;
    }

    /**
     * @description Formats a DateTime into a user-friendly activation-date string
     * @param dt The DateTime to format (may be null)
     * @return String Formatted date or null
     */
    private static String formatActivationDate(Datetime dt) {
        return dt != null ? dt.format('MMM d, yyyy h:mm a') : null;
    }

    /**
     * @description Helper to get existing settings or create new default settings instance
     * @return DeliveryHubSettings__c settings record
     */
    private static DeliveryHubSettings__c getOrCreateSettings() {
        DeliveryHubSettings__c settings = DeliveryHubSettings__c.getOrgDefaults();
        if (settings == null || settings.Id == null) {
            settings = new DeliveryHubSettings__c(SetupOwnerId = UserInfo.getOrganizationId());
        }
        return settings;
    }

    /**
     * @description Saves general application settings
     * @param enableNotifications Whether to enable notifications
     * @param autoCreateRequest Whether to auto-create Requests
     * @param autoSendRequest Whether to auto-send Requests to Vendor
     * @param emailNotificationsEnabled Whether to send email on stage changes
     * @param showBoardMetrics Whether to show inline board metrics on the Kanban board
     * @param reconciliationHour Hour (0-23) for reconciliation job
     * @param syncRetryLimit Max retry attempts for failed syncs
     * @param activityLogRetentionDays Days to retain activity logs
     * @param escalationCooldownHours Hours between repeated escalations
     */
    @SuppressWarnings('PMD.ExcessiveParameterList')
    @AuraEnabled
    public static void saveGeneralSettings(
        Boolean enableNotifications,
        Boolean autoCreateRequest,
        Boolean autoSendRequest,
        Boolean emailNotificationsEnabled,
        Boolean showBoardMetrics,
        Integer reconciliationHour,
        Integer syncRetryLimit,
        Integer activityLogRetentionDays,
        Integer escalationCooldownHours
    ) {
        try {
            DeliveryHubSettings__c settings = getOrCreateSettings();

            settings.EnableNotificationsDateTime__c = enableNotifications ? (settings.EnableNotificationsDateTime__c != null ? settings.EnableNotificationsDateTime__c : Datetime.now()) : null;
            settings.EnableAutoCreateWorkRequestDateTime__c = autoCreateRequest ? (settings.EnableAutoCreateWorkRequestDateTime__c != null ? settings.EnableAutoCreateWorkRequestDateTime__c : Datetime.now()) : null;
            settings.EnableAutoSyncNetworkEntityDateTime__c = autoSendRequest ? (settings.EnableAutoSyncNetworkEntityDateTime__c != null ? settings.EnableAutoSyncNetworkEntityDateTime__c : Datetime.now()) : null;
            settings.EnableEmailNotificationsDateTime__c = (emailNotificationsEnabled == true) ? (settings.EnableEmailNotificationsDateTime__c != null ? settings.EnableEmailNotificationsDateTime__c : Datetime.now()) : null;
            settings.EnableBoardMetricsDateTime__c = (showBoardMetrics == null || showBoardMetrics) ? (settings.EnableBoardMetricsDateTime__c != null ? settings.EnableBoardMetricsDateTime__c : Datetime.now()) : null;

            // Configurable number settings
            settings.ReconciliationHourNumber__c = reconciliationHour != null ? reconciliationHour : 6;
            settings.SyncRetryLimitNumber__c = syncRetryLimit != null ? syncRetryLimit : 3;
            settings.ActivityLogRetentionDaysNumber__c = activityLogRetentionDays != null ? activityLogRetentionDays : 90;
            settings.EscalationCooldownHoursNumber__c = escalationCooldownHours != null ? escalationCooldownHours : 24;

            SObjectAccessDecision decision = Security.stripInaccessible(
                AccessType.UPSERTABLE, new List<DeliveryHubSettings__c>{settings});
            upsert decision.getRecords();
        } catch (Exception e) {
            AuraHandledException ahe = new AuraHandledException(e.getMessage());
            ahe.setMessage(e.getMessage());
            throw ahe;
        }
    }
    
    /**
     * @description Saves AI-related settings
     * @param suggestions Enable AI suggestions
     * @param descriptions Enable auto-generate descriptions
     * @param estimation Enable AI estimation
     */
    @AuraEnabled
    public static void saveAiSettings(Boolean suggestions, Boolean descriptions, Boolean estimation) {
        try {
            DeliveryHubSettings__c settings = getOrCreateSettings();

            settings.EnableAISuggestionsDateTime__c = suggestions ? (settings.EnableAISuggestionsDateTime__c != null ? settings.EnableAISuggestionsDateTime__c : Datetime.now()) : null;
            settings.EnableAutoGenerateDescriptionsDateTime__c = descriptions ? (settings.EnableAutoGenerateDescriptionsDateTime__c != null ? settings.EnableAutoGenerateDescriptionsDateTime__c : Datetime.now()) : null;
            settings.EnableAIEstimationDateTime__c = estimation ? (settings.EnableAIEstimationDateTime__c != null ? settings.EnableAIEstimationDateTime__c : Datetime.now()) : null;

            SObjectAccessDecision decision = Security.stripInaccessible(
                AccessType.UPSERTABLE, new List<DeliveryHubSettings__c>{settings});
            upsert decision.getRecords();
        } catch (Exception e) {
            AuraHandledException ahe = new AuraHandledException(e.getMessage());
            ahe.setMessage(e.getMessage());
            throw ahe;
        }
    }
    
    /**
     * @description Saves OpenAI API settings
     * @param apiKey OpenAI API key
     * @param model OpenAI model name
     * @param tested Whether the API has been tested
     */
    @AuraEnabled
    public static void saveOpenAISettings(String apiKey, String model, boolean tested) {
        try {
            DeliveryHubSettings__c settings = getOrCreateSettings();

            if (String.isNotBlank(apiKey) && !apiKey.startsWith('****')) {
                settings.OpenAIApiKeyTxt__c = apiKey;
            }
            settings.OpenAIModelTxt__c = model;
            settings.OpenAiApiTestedBool__c = tested;

            SObjectAccessDecision decision = Security.stripInaccessible(
                AccessType.UPSERTABLE, new List<DeliveryHubSettings__c>{settings});
            upsert decision.getRecords();
        } catch (Exception e) {
            AuraHandledException ahe = new AuraHandledException(e.getMessage());
            ahe.setMessage(e.getMessage());
            throw ahe;
        }
    }

    /**
     * @description Saves the Slack Incoming Webhook URL to Custom Settings.
     * @param webhookUrl The Slack webhook URL (or blank to clear)
     */
    @AuraEnabled
    public static void saveSlackWebhookUrl(String webhookUrl) {
        try {
            DeliveryHubSettings__c settings = getOrCreateSettings();
            settings.SlackWebhookUrl__c = webhookUrl;
            SObjectAccessDecision decision = Security.stripInaccessible(
                AccessType.UPSERTABLE, new List<DeliveryHubSettings__c>{settings});
            upsert decision.getRecords();
        } catch (Exception e) {
            AuraHandledException ahe = new AuraHandledException(e.getMessage());
            ahe.setMessage(e.getMessage());
            throw ahe;
        }
    }

    /**
     * @description Saves all AI + OpenAI settings from a JSON payload (used by kanban settings container).
     * @param settingsJson JSON string matching SettingsDTO shape
     */
    @AuraEnabled
    public static void saveAllAiSettings(String settingsJson) {
        try {
            SettingsDTO dto = (SettingsDTO) JSON.deserialize(settingsJson, SettingsDTO.class);
            DeliveryHubSettings__c settings = getOrCreateSettings();
            settings.EnableAISuggestionsDateTime__c = dto.aiSuggestionsEnabled ? (settings.EnableAISuggestionsDateTime__c != null ? settings.EnableAISuggestionsDateTime__c : Datetime.now()) : null;
            settings.EnableAutoGenerateDescriptionsDateTime__c = dto.autoGenerateDescriptions ? (settings.EnableAutoGenerateDescriptionsDateTime__c != null ? settings.EnableAutoGenerateDescriptionsDateTime__c : Datetime.now()) : null;
            settings.EnableAIEstimationDateTime__c = dto.aiEstimationEnabled ? (settings.EnableAIEstimationDateTime__c != null ? settings.EnableAIEstimationDateTime__c : Datetime.now()) : null;
            if (String.isNotBlank(dto.openaiApiKey) && !dto.openaiApiKey.startsWith('****')) {
                settings.OpenAIApiKeyTxt__c = dto.openaiApiKey;
            }
            settings.OpenAIModelTxt__c = dto.openaiModel;
            SObjectAccessDecision decision = Security.stripInaccessible(
                AccessType.UPSERTABLE, new List<DeliveryHubSettings__c>{settings});
            upsert decision.getRecords();
        } catch (Exception e) {
            AuraHandledException ahe = new AuraHandledException(e.getMessage());
            ahe.setMessage(e.getMessage());
            throw ahe;
        }
    }

    /**
     * @description Tests the provided OpenAI API key.
     * @param apiKey The API key to test
     * @return String result message
     */
    @SuppressWarnings('PMD.ApexSuggestUsingNamedCred')
    @AuraEnabled
    public static String testOpenAIConnection(String apiKey) {
        HttpRequest req = new HttpRequest();
        req.setEndpoint('https://api.openai.com/v1/chat/completions');
        req.setMethod('POST');
        req.setHeader('Authorization', 'Bearer ' + apiKey);
        req.setHeader('Content-Type', 'application/json');
        req.setBody('{"model": "gpt-4o-mini", "messages": [{"role": "user", "content": "Test"}], "max_tokens": 5}');

        try {
            HttpResponse res = new Http().send(req);
            if (res.getStatusCode() >= 200 && res.getStatusCode() < 300) {
                return 'Success';
            } else {
                return 'Failed: ' + res.getStatusCode() + ' - ' + res.getBody();
            }
        } catch (Exception e) {
            return 'Error: ' + e.getMessage();
        }
    }
}