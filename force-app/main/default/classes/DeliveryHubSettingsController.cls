    /**
     * @description Fetches settings. Not cacheable to ensure fresh reload.
     * @return SettingsDTO The aggregated settings object.
     */
    @SuppressWarnings('PMD.CyclomaticComplexity')
    @AuraEnabled
    global static SettingsDTO getSettings() {
        DeliveryHubSettings__c settings = DeliveryHubSettings__c.getOrgDefaults();
        SettingsDTO dto = new SettingsDTO();

        if (settings != null && settings.Id != null) {
            dto.enableNotifications = settings.EnableNotificationsDateTime__c != null;

            // Map new fields
            dto.autoCreateRequest = settings.EnableAutoCreateWorkRequestDateTime__c != null;
            dto.autoSendRequest = settings.EnableAutoSyncNetworkEntityDateTime__c != null;

            // Map AI fields
            dto.aiSuggestionsEnabled = settings.EnableAISuggestionsDateTime__c != null;
            dto.autoGenerateDescriptions = settings.EnableAutoGenerateDescriptionsDateTime__c != null;
            dto.aiEstimationEnabled = settings.EnableAIEstimationDateTime__c != null;
            dto.openaiApiKey = String.isNotBlank(settings.OpenAIApiKeyTxt__c)
                ? '****' + settings.OpenAIApiKeyTxt__c.right(4)
                : null;
            dto.openaiModel = settings.OpenAIModelTxt__c;
            dto.openAiApiTested = settings.OpenAiApiTestedDateTime__c != null;
            dto.slackWebhookUrl = settings.SlackWebhookUrlTxt__c;
            dto.emailNotificationsEnabled = settings.EnableEmailNotificationsDateTime__c != null;
            dto.showBoardMetrics = settings.EnableBoardMetricsDateTime__c != null;

            // Additional feature toggles
            dto.activityLoggingEnabled = settings.EnableActivityLoggingDateTime__c != null;
            dto.fieldTrackingEnabled = settings.EnableFieldTrackingDateTime__c != null;
            dto.bellNotificationsEnabled = settings.EnableBellNotificationsDateTime__c != null;
            dto.weeklyDigestEnabled = settings.EnableWeeklyDigestDateTime__c != null;
            dto.statusPageEnabled = settings.EnableStatusPageDateTime__c != null;
            dto.autoCreateWorkRequest = settings.EnableAutoCreateWorkRequestDateTime__c != null;
            dto.requireWorkLogApproval = settings.RequireWorkLogApprovalDateTime__c != null;

            // Activation-date strings
            dto.notificationsActivatedAt = formatActivationDate(settings.EnableNotificationsDateTime__c);
            dto.autoSyncActivatedAt = formatActivationDate(settings.EnableAutoSyncNetworkEntityDateTime__c);
            dto.emailNotificationsActivatedAt = formatActivationDate(settings.EnableEmailNotificationsDateTime__c);
            dto.boardMetricsActivatedAt = formatActivationDate(settings.EnableBoardMetricsDateTime__c);
            dto.activityLoggingActivatedAt = formatActivationDate(settings.EnableActivityLoggingDateTime__c);
            dto.fieldTrackingActivatedAt = formatActivationDate(settings.EnableFieldTrackingDateTime__c);
            dto.bellNotificationsActivatedAt = formatActivationDate(settings.EnableBellNotificationsDateTime__c);
            dto.weeklyDigestActivatedAt = formatActivationDate(settings.EnableWeeklyDigestDateTime__c);
            dto.statusPageActivatedAt = formatActivationDate(settings.EnableStatusPageDateTime__c);
            dto.autoCreateWorkRequestActivatedAt = formatActivationDate(settings.EnableAutoCreateWorkRequestDateTime__c);
            dto.requireWorkLogApprovalActivatedAt = formatActivationDate(settings.RequireWorkLogApprovalDateTime__c);

            // Configurable number settings (with defaults)
            dto.reconciliationHour = settings.ReconciliationHourNumber__c != null
                ? Integer.valueOf(settings.ReconciliationHourNumber__c) : 6;
            dto.syncRetryLimit = settings.SyncRetryLimitNumber__c != null
                ? Integer.valueOf(settings.SyncRetryLimitNumber__c) : 3;
            dto.activityLogRetentionDays = settings.ActivityLogRetentionDaysNumber__c != null
                ? Integer.valueOf(settings.ActivityLogRetentionDaysNumber__c) : 90;
            dto.escalationCooldownHours = settings.EscalationCooldownHoursNumber__c != null
                ? Integer.valueOf(settings.EscalationCooldownHoursNumber__c) : 24;
            dto.fieldChangeRetentionDays = settings.FieldChangeRetentionDaysNumber__c != null
                ? Integer.valueOf(settings.FieldChangeRetentionDaysNumber__c) : 0;

            // Text configuration settings
            dto.weeklyDigestDay = settings.WeeklyDigestDayTxt__c != null ? settings.WeeklyDigestDayTxt__c : 'Monday';
            dto.weeklyDigestRecipients = settings.WeeklyDigestRecipientsTxt__c;
            dto.documentCcEmail = settings.DocumentCcEmailTxt__c;
            dto.documentFromOrgWideEmail = settings.DocumentFromOrgWideEmailTxt__c;
            dto.statusPageToken = settings.StatusPageTokenTxt__c;
            dto.defaultBillingEntityId = settings.DefaultBillingEntityIdTxt__c;
            dto.stagesToAutoShare = settings.StagesToAutoShareWithDevTeamTxt__c;
            dto.webhookUrl = settings.WebhookUrlTxt__c;

            // Invoice generation
            dto.invoiceGenerationEnabled = settings.EnableInvoiceGenerationDateTime__c != null;
            dto.invoiceGenerationActivatedAt = formatActivationDate(settings.EnableInvoiceGenerationDateTime__c);

            // Checkout Cart settings
            dto.cartDollarsEnabled = settings.EnableCartDollarsDateTime__c != null;
            dto.cartDollarsActivatedAt = formatActivationDate(settings.EnableCartDollarsDateTime__c);
            dto.cartSelfServeEnabled = settings.EnableCartSelfServeDateTime__c != null;
            dto.cartSelfServeActivatedAt = formatActivationDate(settings.EnableCartSelfServeDateTime__c);
            dto.checkoutMode = String.isNotBlank(settings.CheckoutModeTxt__c)
                ? settings.CheckoutModeTxt__c : 'Invoice';

            // Enterprise / API settings
            dto.syncApiRateLimit = settings.SyncApiRateLimitNumber__c != null
                ? Integer.valueOf(settings.SyncApiRateLimitNumber__c) : null;
            dto.publicApiRateLimit = settings.PublicApiRateLimitNumber__c != null
                ? Integer.valueOf(settings.PublicApiRateLimitNumber__c) : null;
            dto.externalNotificationsEnabled = settings.EnableExternalNotificationsDateTime__c != null;
            dto.externalNotificationsActivatedAt = formatActivationDate(settings.EnableExternalNotificationsDateTime__c);
            dto.overdueRemindersEnabled = settings.EnableOverdueRemindersDateTime__c != null;
            dto.overdueRemindersActivatedAt = formatActivationDate(settings.EnableOverdueRemindersDateTime__c);
            dto.overdueReminderSchedule = settings.OverdueReminderScheduleTxt__c != null
                ? settings.OverdueReminderScheduleTxt__c : '1,7,14,30';
            dto.resourceTitleAutoFillEnabled = settings.EnableResourceTitleAutoFillDateTime__c != null;
            dto.resourceTitleAutoFillActivatedAt = formatActivationDate(settings.EnableResourceTitleAutoFillDateTime__c);
            dto.invoiceHourLockoutDay = settings.InvoiceHourLockoutDayNumber__c != null
                ? Integer.valueOf(settings.InvoiceHourLockoutDayNumber__c) : null;
            dto.invoiceHourLockoutTime = settings.InvoiceHourLockoutTimeNumber__c != null
                ? Integer.valueOf(settings.InvoiceHourLockoutTimeNumber__c) : null;
        } else {
            // Fresh Install Defaults — match what DeliveryHubInstallHandler sets
            dto.enableNotifications = true;
            dto.autoCreateRequest = true;
            dto.autoSendRequest = true;
            dto.emailNotificationsEnabled = true;
            dto.showBoardMetrics = true;
            dto.aiSuggestionsEnabled = true;
            dto.autoGenerateDescriptions = true;
            dto.aiEstimationEnabled = true;
            dto.activityLoggingEnabled = false;
            dto.fieldTrackingEnabled = false;
            dto.bellNotificationsEnabled = false;
            dto.weeklyDigestEnabled = false;
            dto.statusPageEnabled = false;
            dto.autoCreateWorkRequest = true;
            dto.requireWorkLogApproval = false;
            dto.reconciliationHour = 6;
            dto.syncRetryLimit = 3;
            dto.activityLogRetentionDays = 90;
            dto.escalationCooldownHours = 24;
            dto.fieldChangeRetentionDays = 0;
            dto.weeklyDigestDay = 'Monday';
            dto.invoiceGenerationEnabled = false;
            dto.externalNotificationsEnabled = false;
            dto.overdueRemindersEnabled = false;
            dto.overdueReminderSchedule = '1,7,14,30';
            dto.resourceTitleAutoFillEnabled = false;
            // Checkout Cart defaults — dollars off org-wide (MF behavior), admin
            // assembles, Invoice routing.
            dto.cartDollarsEnabled = false;
            dto.cartSelfServeEnabled = false;
            dto.checkoutMode = 'Invoice';
        }
        return dto;
    }

    /**
     * @description Formats a DateTime into a user-friendly activation-date string
     * @param dt The DateTime to format (may be null)
     * @return String Formatted date or null
     */
    private static String formatActivationDate(Datetime dt) {
        return dt != null ? dt.format('MMM d, yyyy h:mm a') : null;
    }

    /**
     * @description Helper to get existing settings or create new default settings instance
     * @return DeliveryHubSettings__c settings record
     */
    private static DeliveryHubSettings__c getOrCreateSettings() {
        DeliveryHubSettings__c settings = DeliveryHubSettings__c.getOrgDefaults();
        if (settings == null || settings.Id == null) {
            settings = new DeliveryHubSettings__c(SetupOwnerId = UserInfo.getOrganizationId());
        }
        return settings;
    }

    /**
     * @description Saves general application settings
     * @param enableNotifications Whether to enable notifications
     * @param autoCreateRequest Whether to auto-create Requests
     * @param autoSendRequest Whether to auto-send Requests to Vendor
     * @param emailNotificationsEnabled Whether to send email on stage changes
     * @param showBoardMetrics Whether to show inline board metrics on the Kanban board
     * @param reconciliationHour Hour (0-23) for reconciliation job
     * @param syncRetryLimit Max retry attempts for failed syncs
     * @param activityLogRetentionDays Days to retain activity logs
     * @param escalationCooldownHours Hours between repeated escalations
     */
    @SuppressWarnings('PMD.ExcessiveParameterList')
    @AuraEnabled
    global static void saveGeneralSettings(
        Boolean enableNotifications,
        Boolean autoCreateRequest,
        Boolean autoSendRequest,
        Boolean emailNotificationsEnabled,
        Boolean showBoardMetrics,
        Integer reconciliationHour,
        Integer syncRetryLimit,
        Integer activityLogRetentionDays,
        Integer escalationCooldownHours
    ) {
        try {
            DeliveryHubSettings__c settings = getOrCreateSettings();

            settings.EnableNotificationsDateTime__c = enableNotifications ? (settings.EnableNotificationsDateTime__c != null ? settings.EnableNotificationsDateTime__c : Datetime.now()) : null;
            settings.EnableAutoCreateWorkRequestDateTime__c = autoCreateRequest ? (settings.EnableAutoCreateWorkRequestDateTime__c != null ? settings.EnableAutoCreateWorkRequestDateTime__c : Datetime.now()) : null;
            settings.EnableAutoSyncNetworkEntityDateTime__c = autoSendRequest ? (settings.EnableAutoSyncNetworkEntityDateTime__c != null ? settings.EnableAutoSyncNetworkEntityDateTime__c : Datetime.now()) : null;
            settings.EnableEmailNotificationsDateTime__c = (emailNotificationsEnabled == true) ? (settings.EnableEmailNotificationsDateTime__c != null ? settings.EnableEmailNotificationsDateTime__c : Datetime.now()) : null;
            settings.EnableBoardMetricsDateTime__c = (showBoardMetrics == null || showBoardMetrics) ? (settings.EnableBoardMetricsDateTime__c != null ? settings.EnableBoardMetricsDateTime__c : Datetime.now()) : null;

            // Configurable number settings
            settings.ReconciliationHourNumber__c = reconciliationHour != null ? reconciliationHour : 6;
            settings.SyncRetryLimitNumber__c = syncRetryLimit != null ? syncRetryLimit : 3;
            settings.ActivityLogRetentionDaysNumber__c = activityLogRetentionDays != null ? activityLogRetentionDays : 90;
            settings.EscalationCooldownHoursNumber__c = escalationCooldownHours != null ? escalationCooldownHours : 24;

            SObjectAccessDecision decision = Security.stripInaccessible(
                AccessType.UPSERTABLE, new List<DeliveryHubSettings__c>{settings});
            upsert decision.getRecords();
        } catch (Exception e) {
            AuraHandledException ahe = new AuraHandledException(e.getMessage());
            ahe.setMessage(e.getMessage());
            throw ahe;
        }
    }
    
    /**
     * @description Saves extended settings (feature toggles, text configs, numbers) from JSON payload.
     * Used by the General Settings card for newly exposed fields.
     * @param settingsJson JSON string matching SettingsDTO shape
     */
    @AuraEnabled
    global static void saveExtendedSettings(String settingsJson) {
        try {
            SettingsDTO dto = (SettingsDTO) JSON.deserialize(settingsJson, SettingsDTO.class);
            DeliveryHubSettings__c settings = getOrCreateSettings();

            // Feature toggles (DateTime-based)
            settings.EnableActivityLoggingDateTime__c = dto.activityLoggingEnabled ? (settings.EnableActivityLoggingDateTime__c != null ? settings.EnableActivityLoggingDateTime__c : Datetime.now()) : null;
            settings.EnableFieldTrackingDateTime__c = dto.fieldTrackingEnabled ? (settings.EnableFieldTrackingDateTime__c != null ? settings.EnableFieldTrackingDateTime__c : Datetime.now()) : null;
            settings.EnableBellNotificationsDateTime__c = dto.bellNotificationsEnabled ? (settings.EnableBellNotificationsDateTime__c != null ? settings.EnableBellNotificationsDateTime__c : Datetime.now()) : null;
            settings.EnableWeeklyDigestDateTime__c = dto.weeklyDigestEnabled ? (settings.EnableWeeklyDigestDateTime__c != null ? settings.EnableWeeklyDigestDateTime__c : Datetime.now()) : null;
            settings.EnableStatusPageDateTime__c = dto.statusPageEnabled ? (settings.EnableStatusPageDateTime__c != null ? settings.EnableStatusPageDateTime__c : Datetime.now()) : null;
            settings.EnableAutoCreateWorkRequestDateTime__c = dto.autoCreateWorkRequest ? (settings.EnableAutoCreateWorkRequestDateTime__c != null ? settings.EnableAutoCreateWorkRequestDateTime__c : Datetime.now()) : null;
